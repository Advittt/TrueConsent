# TokenRouter API key used by /api/analyze to route Claude requests through
# https://api.tokenrouter.com. Generate one in your TokenRouter dashboard.
tokenrouter=

# Optional: override the default model identifier (TokenRouter uses
# `<provider>/<model>` slugs, e.g. anthropic/claude-opus-4.7).
# TOKENROUTER_MODEL=anthropic/claude-opus-4.7

# Optional: override the TokenRouter base URL (default: https://api.tokenrouter.com).
# TOKENROUTER_BASE_URL=https://api.tokenrouter.com
